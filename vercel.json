{
  "redirects": [
    {
      "source": "/vinilos",
      "destination": "/u/shibu",
      "permanent": true
    },
    {
      "source": "/vinilos/add",
      "destination": "/add",
      "permanent": true
    },
    {
      "source": "/vinilos/:path*",
      "destination": "/u/shibu",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/explore.html"
    },
    {
      "source": "/explore",
      "destination": "/explore.html"
    },
    {
      "source": "/u/:username([a-z0-9-]+)",
      "destination": "/index.html"
    },
    {
      "source": "/add",
      "destination": "/add.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    }
  ],
  "crons": [
    {
      "path": "/api/keepalive",
      "schedule": "0 9 * * *"
    }
  ]
}
